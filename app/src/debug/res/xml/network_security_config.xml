<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only override: allows cleartext to the emulator's host alias so
     synthetic ICS fixtures can be served from the dev machine during testing.
     Release builds use the main config (https everywhere, no exceptions). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
